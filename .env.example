# ============================================================
# Tajir Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ─── Firebase ─────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ─── AI Models (Hybrid: DeepSeek + Claude) ────────────────────
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# AI Router Configuration
DEFAULT_AI_PROVIDER=claude
FALLBACK_AI_PROVIDER=deepseek

# ─── Market Data ──────────────────────────────────────────────
TWELVE_DATA_API_KEY=your-key

# ─── Broker (Pepperstone FIX Protocol) ────────────────────────
PEPPERSTONE_HOST=fix.pepperstone.com
PEPPERSTONE_PORT=443
PEPPERSTONE_SENDER_COMP_ID=YOUR_COMP_ID
PEPPERSTONE_TARGET_COMP_ID=PEPPERSTONE
PEPPERSTONE_USERNAME=your-username
PEPPERSTONE_PASSWORD=your-password

# ─── Payments (Stripe) ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_BASIC=price_...
STRIPE_PRICE_ID_PRO=price_...

# ─── SMS (Twilio) ────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-token
TWILIO_FROM_NUMBER=+1234567890

# ─── Monitoring ──────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Security ────────────────────────────────────────────────
JWT_SECRET_KEY=generate-a-strong-random-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Application ─────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AI_PER_MINUTE=20
