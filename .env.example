# ─── AI PROVIDERS ─────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
DEFAULT_AI_PROVIDER=deepseek
FALLBACK_AI_PROVIDER=claude
CLAUDE_MODEL_ID=claude-3-sonnet-20240229
AI_ROUTES_AVAILABLE=true

# ─── AWS ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1

# ─── SUPABASE ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── DATABASE ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── REDIS ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=your_jwt_secret_key_here

# ─── TWELVE DATA ──────────────────────────────────────────────
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# ─── BREVO (EMAIL) ────────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key_here
BREVO_FROM_EMAIL=noreply@yourdomain.com

# ─── TWILIO ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+10000000000
TWILIO_WHATSAPP_NUMBER=whatsapp:+10000000000

# ─── FIREBASE ─────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_APP_ID=your_firebase_app_id
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_WEB_API_KEY=your_firebase_web_api_key_here
FIREBASE_KEY_PATH=./firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_JSON_B64=your_base64_encoded_service_account_json_here
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# ─── FRONTEND ─────────────────────────────────────────────────
FRONTEND_APP_URL=http://localhost:3000

# ─── CORS ─────────────────────────────────────────────────────
CORS_EXTRA_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOWED_ORIGIN_REGEX=^https://.*\.yourdomain\.com$

# ─── APP ENVIRONMENT ──────────────────────────────────────────
DEBUG=false
ENVIRONMENT=development

# ─── EMAIL URLS ───────────────────────────────────────────────
EMAIL_PROVIDER=brevo
PASSWORD_RESET_CONTINUE_URL=http://localhost:3000/reset-password
EMAIL_VERIFICATION_CONTINUE_URL=http://localhost:3000/verify-email

# ─── DEV AUTH ─────────────────────────────────────────────────
ALLOW_DEV_USER_ID=false
DEV_USER_LOCALHOST_ONLY=true
DEV_AUTH_SHARED_SECRET=your_dev_auth_shared_secret_here

# ─── PEPPERSTONE PRICE (QUOTE) ────────────────────────────────
PEPPERSTONE_ACCOUNT_ID=your_account_id_here
PEPPERSTONE_PASSWORD=your_account_password_here
PEPPERSTONE_PRICE_HOST=demo-us-eqx-01.p.c-trader.com
PEPPERSTONE_PRICE_PORT_SSL=5211
PEPPERSTONE_PRICE_PORT_PLAIN=5201
PEPPERSTONE_PRICE_SENDER_COMP_ID=demo.pepperstone.your_account_id
PEPPERSTONE_PRICE_TARGET_COMP_ID=cServer
PEPPERSTONE_PRICE_SENDER_SUB_ID=QUOTE

# ─── PEPPERSTONE TRADE ────────────────────────────────────────
PEPPERSTONE_TRADE_HOST=demo-us-eqx-01.p.c-trader.com
PEPPERSTONE_TRADE_PORT_SSL=5212
PEPPERSTONE_TRADE_PORT_PLAIN=5202
PEPPERSTONE_TRADE_SENDER_COMP_ID=demo.pepperstone.your_account_id
PEPPERSTONE_TRADE_TARGET_COMP_ID=cServer
PEPPERSTONE_TRADE_SENDER_SUB_ID=TRADE

# ─── TRADING CONFIG ───────────────────────────────────────────
TRADING_SERVER=demo
USE_SSL_FIX=true
TRADING_API_PORT=8001
TRADING_ML_ENABLED=false
LOG_TRADING_ACTIVITY=true
PEPPERSTONE_LIVE_EXECUTION=false
PEPPERSTONE_DEFAULT_ACCOUNT_MODE=demo

# ========================== anthropic-claude-sonnet-==========================
# ─── AWS BEDROCK (Claude via Amazon) ─────────────────────────
AWS_ACCESS_KEY_ID=demo-access-key-id
AWS_SECRET_ACCESS_KEY=demo-secret-access-key
AWS_REGION=us-east-1

BEDROCK_MODEL_ID=us account_id_here.claude-sonnet-20240229
BEDROCK_MAX_TOKENS=1000
BEDROCK_ANTHROPIC_VERSION=bedrock-2023-09-30
